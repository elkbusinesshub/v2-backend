# ─── App ─────────────────────────────────────────────────────────────────────
# development | test | staging | production
NODE_ENV=development
PORT=3000
# Comma-separated list of allowed origins for CORS and Socket.IO
CORS_ORIGINS=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
# matches docker-compose (host port 5433)
DATABASE_URL=postgresql://elk:elk@localhost:5433/elk?schema=public

# ─── Redis ───────────────────────────────────────────────────────────────────
# matches docker-compose (host port 6380)
REDIS_URL=redis://localhost:6380

# ─── Auth ────────────────────────────────────────────────────────────────────
# MUST be at least 32 chars. Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-change-me-change-me-change-me-change-me
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

# ─── Rate limiting (global default) ──────────────────────────────────────────
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100

# ─── Storage (S3-compatible) ─────────────────────────────────────────────────
S3_REGION=me-central-1
S3_BUCKET=elk-dev
# Set for MinIO/localstack; leave empty for real AWS
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
# Leave empty in production — use IAM task roles instead of static keys
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Observability / docs ────────────────────────────────────────────────────
# fatal | error | warn | info | debug | trace
LOG_LEVEL=debug
# Swagger UI is force-disabled in production regardless of this flag
SWAGGER_ENABLED=true
